# Google サービスアカウント認証情報 JSON のパス
GOOGLE_APPLICATION_CREDENTIALS=credentials/service_account.json

# Anthropic API キー
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API キー（スキャン PDF の OCR に使用）
GEMINI_API_KEY=AIza...

# パイプライン実行パラメータ
DRIVE_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxx
DEPARTMENT=marketing
GROWI_BASE_URL=https://growi.example.com
GROWI_API_TOKEN=your-token-here
# Google Form のプレフィル URL（PLACEHOLDER_DOC_ID と PLACEHOLDER_DATE をそのまま残す）
FORM_BASE_URL=https://docs.google.com/forms/d/e/xxxxxxxx/viewform?usp=pp_url&entry.xxxxxxxxx=PLACEHOLDER_DOC_ID&entry.xxxxxxxxx=PLACEHOLDER_DATE
